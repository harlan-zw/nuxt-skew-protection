{
  "name": "nuxt-skew-protection",
  "type": "module",
  "version": "0.7.0",
  "packageManager": "pnpm@10.27.0",
  "description": "Solve Nuxt version skews with persistent assets and instant updates.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://nuxtseo.com/skew-protection",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/nuxt-skew-protection.git"
  },
  "bugs": {
    "url": "https://github.com/harlan-zw/nuxt-skew-protection/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./server": "./dist/runtime/server/index.js",
    "./adapters": "./dist/runtime/adapters/index.js",
    "./adapters/pusher": "./dist/runtime/adapters/pusher/index.js",
    "./adapters/pusher/web": "./dist/runtime/adapters/pusher/web.js",
    "./adapters/pusher/node": "./dist/runtime/adapters/pusher/node.js",
    "./adapters/ably": "./dist/runtime/adapters/ably/index.js",
    "./adapters/ably/web": "./dist/runtime/adapters/ably/web.js",
    "./adapters/ably/node": "./dist/runtime/adapters/ably/node.js"
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && unbuild --config sw.build.config.ts",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && nuxi prepare playground",
    "release": "pnpm build && bumpp -x \"npx changelogen --output=CHANGELOG.md\"",
    "prepack": "pnpm run build",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:watch": "vitest",
    "test:cloudflare-polling": "node --experimental-strip-types scripts/test-cloudflare-polling.ts",
    "test:node-sse": "node --experimental-strip-types scripts/test-node-sse.ts",
    "test:node-polling": "node --experimental-strip-types scripts/test-node-polling.ts",
    "test:node-ws": "node --experimental-strip-types scripts/test-node-ws.ts",
    "test:static-polling": "node --experimental-strip-types scripts/test-static-polling.ts",
    "test:vercel-sse": "node --experimental-strip-types scripts/test-vercel-sse.ts",
    "typecheck": "nuxt typecheck",
    "test:attw": "attw --pack"
  },
  "peerDependencies": {
    "@nuxtjs/robots": ">=5.6.7",
    "ably": ">=2",
    "pusher-js": ">=8"
  },
  "peerDependenciesMeta": {
    "ably": {
      "optional": true
    },
    "pusher-js": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@nuxt/kit": "^4.2.2",
    "@vueuse/core": "^14.1.0",
    "consola": "^3.4.2",
    "cookie-es": "^2.0.0",
    "defu": "^6.1.4",
    "nuxt-site-config": "^3.2.14",
    "ofetch": "^1.5.1",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.0",
    "std-env": "^3.10.0",
    "tinyexec": "^1.0.2",
    "ufo": "^1.6.1",
    "unstorage": "^1.17.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "@nuxt/content": "^3.10.0",
    "@nuxt/devtools-ui-kit": "^3.1.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^3.22.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/i18n": "^10.2.1",
    "@nuxtjs/robots": "^5.6.7",
    "@types/ioredis": "^5.0.0",
    "@types/ws": "^8.18.1",
    "@unocss/nuxt": "66.5.12",
    "@unocss/preset-icons": "66.5.12",
    "@unocss/preset-uno": "66.5.12",
    "@unocss/runtime": "66.5.12",
    "@vueuse/nuxt": "^14.1.0",
    "ably": "^2.16.0",
    "better-sqlite3": "^12.5.0",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "eventsource": "^4.1.0",
    "execa": "^9.6.1",
    "firebase-functions": "^7.0.2",
    "happy-dom": "^20.0.11",
    "ioredis": "^5.9.0",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.26",
    "playwright-core": "^1.57.0",
    "pusher-js": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unocss": "66.5.12",
    "vitest": "^4.0.16",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.2",
    "wrangler": "^4.54.0",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "resolutions": {
    "nuxt-skew-protection": "workspace:*",
    "reka-ui": "2.6.1"
  }
}
